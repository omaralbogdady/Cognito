rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Global Safety Net: Default Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Helper Functions (Phase 3)
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin') ||
        (request.auth.token.email == "oalbogdady1@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // User Profiles
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'calendarSyncEnabled', 'aiEnabled', 'hasCompletedOnboarding']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 255 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (data.photoURL is string && data.photoURL.size() <= 1000 || data.photoURL == null) &&
             data.calendarSyncEnabled is bool &&
             data.aiEnabled is bool &&
             data.hasCompletedOnboarding is bool &&
             (!('themeColor' in data) || data.themeColor is string && data.themeColor.size() <= 50) &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      isValidId(userId) &&
                      incoming().keys().size() >= 7 && // required + optional count
                      incoming().keys().size() <= 9;
      
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      // Users cannot change their own role unless they are already admin
                      (!incoming().diff(existing()).affectedKeys().hasAny(['role']) || isAdmin()) &&
                      incoming().uid == existing().uid &&
                      incoming().email == existing().email;
                      
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Tasks (Assignments and Exams)
    // ===============================================================
    
    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'type', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.type in ['assignment', 'exam'] &&
             data.status in ['pending', 'completed'] &&
             data.createdAt is timestamp &&
             (!('priority' in data) || data.priority in ['low', 'medium', 'high']) &&
             (!('progress' in data) || (data.progress is number && data.progress >= 0 && data.progress <= 100)) &&
             (!('description' in data) || data.description is string && data.description.size() <= 1000) &&
             (!('dueDate' in data) || data.dueDate is timestamp) &&
             (!('calendarEventId' in data) || data.calendarEventId is string && data.calendarEventId.size() <= 255) &&
             (!('recurrence' in data) || data.recurrence in ['daily', 'weekly', 'monthly', 'none']) &&
             (!('parentId' in data) || (data.parentId is string && isValidId(data.parentId)));
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                      isValidTask(incoming()) && 
                      isValidId(taskId) &&
                      incoming().createdAt == request.time &&
                      incoming().keys().size() >= 5 &&
                      incoming().keys().size() <= 12;
      
      allow update: if isSignedIn() && 
                      (existing().userId == request.auth.uid || isAdmin()) &&
                      isValidTask(incoming()) &&
                      incoming().userId == existing().userId && 
                      incoming().createdAt == existing().createdAt &&
                      (!('parentId' in existing()) || incoming().parentId == existing().parentId);
                      
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());

      // ===============================================================
      // Sub-tasks
      // ===============================================================
      
      function isValidSubTask(data) {
        return data.keys().hasAll(['taskId', 'title', 'completed', 'order']) &&
               data.taskId == taskId &&
               data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
               data.completed is bool &&
               data.order is number;
      }

      function isParentOwner() {
        return isSignedIn() && 
               exists(/databases/$(database)/documents/tasks/$(taskId)) &&
               get(/databases/$(database)/documents/tasks/$(taskId)).data.userId == request.auth.uid;
      }

      match /subtasks/{subtaskId} {
        allow read: if isParentOwner() || isAdmin();
        allow create: if isParentOwner() && isValidSubTask(incoming()) && isValidId(subtaskId) && incoming().keys().size() == 4;
        allow update: if isParentOwner() && isValidSubTask(incoming()) && incoming().taskId == existing().taskId;
        allow delete: if isParentOwner() || isAdmin();
      }

      // ===============================================================
      // Notes
      // ===============================================================
      
      function isValidNote(data) {
        return data.keys().hasAll(['taskId', 'type']) &&
               data.taskId == taskId &&
               data.type in ['concept', 'flashcard'] &&
               (data.type == 'concept' ? (
                 data.content is string && data.content.size() <= 10000 && 
                 !data.keys().hasAny(['question', 'answer', 'hint'])
               ) : (
                 data.question is string && data.question.size() <= 1000 && 
                 data.answer is string && data.answer.size() <= 2000 && 
                 (!('hint' in data) || data.hint is string && data.hint.size() <= 1000) &&
                 !data.keys().hasAny(['content'])
               ));
      }

      match /notes/{noteId} {
        allow read: if isParentOwner() || isAdmin();
        allow create: if isParentOwner() && isValidNote(incoming()) && isValidId(noteId);
        allow update: if isParentOwner() && isValidNote(incoming()) && incoming().taskId == existing().taskId;
        allow delete: if isParentOwner() || isAdmin();
      }
    }
  }
}
